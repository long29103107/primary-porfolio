---
import Theme from "@/icons/themeSwitch.astro";
---

<div class="no-print inline-flex items-center">
	<label class="group/theme flex cursor-pointer items-center gap-2 px-3 py-2">
		<span class="flex items-center gap-1 text-sm font-medium leading-6 text-skin-base transition-transform ease-in-out group-hover/theme:rotate-45">
			<Theme />
		</span>
		<span
			class="ring-skin-muted relative inline-flex h-7 w-12 shrink-0 rounded-full bg-skin-fill ring-1 ring-inset transition-colors dark:bg-skin-surface has-[:focus-visible]:ring-2 has-[:focus-visible]:ring-skin-hue"
		>
			<input
				type="checkbox"
				id="themeSwitch"
				name="themeSwitch"
				role="switch"
				aria-checked="false"
				aria-label="Dark mode"
				class="peer absolute inset-0 z-10 h-full w-full cursor-pointer opacity-0"
			/>
			<span
				aria-hidden="true"
				class="pointer-events-none absolute left-0.5 top-0.5 h-6 w-6 rounded-full bg-sky-600 shadow ring-1 ring-black/10 transition-transform duration-200 ease-in-out peer-checked:translate-x-5 peer-checked:bg-white peer-checked:ring-black/5 dark:bg-sky-500"
			></span>
		</span>
	</label>

	<style>
		:global(.dark) {
			color-scheme: dark;
		}
	</style>

	<script>
		const input = document.getElementById("themeSwitch") as HTMLInputElement;
		const stored = localStorage.getItem("theme");
		const systemIsDark = window.matchMedia("(prefers-color-scheme: dark)").matches;

		const isDark =
			stored === "dark" ? true : stored === "light" ? false : systemIsDark;

		input.checked = isDark;
		input.setAttribute("aria-checked", String(isDark));

		function applyTheme(dark: boolean, persist: boolean) {
			document.documentElement.classList.remove("light", "dark");
			document.documentElement.classList.add(dark ? "dark" : "light");
			input.setAttribute("aria-checked", String(dark));
			if (persist) {
				localStorage.setItem("theme", dark ? "dark" : "light");
			}
		}

		applyTheme(isDark, false);

		input.addEventListener("change", () => {
			applyTheme(input.checked, true);
		});
	</script>
</div>
