---
import Section from "../Section.astro";
import { softSkills } from "@cv";
---

<Section className={Astro.props.className} title="Soft skills">
	<ul class="[&>li>svg]:text-skin-hue inline-flex flex-wrap gap-6 [&>li>svg]:size-5 [&>li]:text-sm">
		{
			softSkills.length > 0 && softSkills.map((softSkill) => {
				return (
					<li class="flex items-center gap-1 rounded-md border border-solid border-skin-hue/20 bg-skin-button-accent/20 px-2 py-0.5 text-xs text-skin-muted print:border-none print:bg-transparent print:p-0 print:text-zinc-800 dark:border-skin-muted dark:bg-skin-button-muted dark:text-skin-on-muted">
						<span>{softSkill}</span>
					</li>
				);
			})
		}
	</ul>
</Section>
